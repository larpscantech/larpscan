# Copy to .env.local and fill in values.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Browserless (Playwright sessions) ─────────────────────────────────────────
BROWSERLESS_TOKEN=

# ── BSC investigation wallet (server-side only — never expose to client) ───
INVESTIGATION_WALLET_PRIVATE_KEY=
NODEREAL_RPC=

# ── Optional integrations ─────────────────────────────────────────────────────
X_BEARER_TOKEN=
MORALIS_API_KEY=

# ── WalletConnect / site ──────────────────────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_SITE_URL=https://www.larpscan.sh

# ── NFA contract (public) ─────────────────────────────────────────────────────
NEXT_PUBLIC_NFA_CONTRACT_ADDRESS=0x15b15df2ffff6653c21c11b93fb8a7718ce854ce
NEXT_PUBLIC_PLATFORM_LOGIC_ADDRESS=0x4155b2DcF0200eE266F73a199a4b10E8CD755841

# ── Internal API auth (server-to-server claim dispatch) ───────────────────────
INTERNAL_API_KEY=

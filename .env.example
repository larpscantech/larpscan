# Copy to .env.local — OPENAI_API_KEY, Supabase, wallet keys, etc.

# ── Residential Proxy (optional) ──────────────────────────────────────────────
# Routes Playwright browser traffic through a residential IP so services like
# Privy don't block requests from datacenter IPs.
# Format: http://username:password@host:port
# Providers: geonode.com, proxyon.io, webshare.io (~$1-2/GB, $5 minimum)
# PROXY_URL=http://user:pass@gate.geonode.com:9000

# Copy to .env.local and fill in values.

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Browserless (Playwright sessions) ─────────────────────────────────────────
BROWSERLESS_TOKEN=

# ── Solana investigation wallet (server-side only — base58 secret key or JSON array) ──
INVESTIGATION_WALLET_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ── Optional integrations ─────────────────────────────────────────────────────
HELIUS_API_KEY=
X_BEARER_TOKEN=

# ── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.larpscan.sh

# ── Internal API auth (server-to-server claim dispatch) ───────────────────────
INTERNAL_API_KEY=
